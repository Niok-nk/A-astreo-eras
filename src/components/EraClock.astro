---
import { formatearPosicion, type TimePosition} from '../core'
import EraCard from './EraCard.astro'

const { posicion } = Astro.props as { posicion: TimePosition | null }
const texto = posicion ? formatearPosicion(posicion) : 'Ingresá tu fecha de nacimiento'
---

<div class="clock">
  <div class="cards">
    <EraCard label="Era" value={posicion?.era ?? '—'} />
    <EraCard label="Período" value={posicion?.periodo ?? '—'} />
    <EraCard label="Semana" value={posicion?.semana ?? '—'} />
    <EraCard label="Día" value={posicion?.dia ?? '—'} />
  </div>
  <p class="subtitle">{texto}</p>
  <p class="compact">
    [ {posicion?.era ?? '—'} | {posicion?.periodo ?? '—'} | {posicion?.semana ?? '—'} | {posicion?.dia ?? '—'} ]
  </p>
</div>

<style>
  .clock {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 2rem;
  }
  .cards {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (min-width: 480px) {
    .cards {
      gap: 2rem;
    }
  }
  .subtitle {
    margin-top: 0.75rem;
    opacity: 0.6;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .compact {
    margin-top: 1.5rem;
    font-size: 1rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    opacity: 0.7;
    cursor: pointer;
  }
</style>
