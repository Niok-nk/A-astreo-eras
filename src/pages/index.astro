---
import BaseLayout from "../layouts/BaseLayout.astro";
import EraClock from "../components/EraClock.astro";
---

<BaseLayout>
	<h1>Eras</h1>

	<div class="form">
		<div class="fechas">
			<label for="birthdate">Fecha de nacimiento</label>
			<input type="date" id="birthdate" />
		</div>
		<div class="fechas">
			<label for="refdate">Fecha de referencia</label>
			<input type="date" id="refdate" />
		</div>
		<button id="calcular">Calcular</button>
	</div>

	<EraClock posicion={null} />
</BaseLayout>

<style>
	h1 {
		text-align: center;
	}

	.form {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		margin-top: 2rem;
		padding: 2rem 1.5rem;
	}

	@media (min-width: 768px) {
		.form {
			border-right: 1px solid var(--color-bg-card);
			border-left: 1px solid var(--color-bg-card);
			padding: 20dvh 5rem;
		}
	}
	.fechas{
		margin-bottom: 2rem;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1rem;
	}
	input {
		padding: 0.5rem 1rem;
		font-size: 1rem;
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		background-color: var(--color-bg-main);
		letter-spacing: 0.2rem;
	}
	button {
		padding: 0.5rem 1.5rem;
		font-size: 1rem;
		cursor: pointer;
		background: var(--color-accent);
		color: var(--color-accent-text);
		border: none;
		border-radius: 0.5rem;
	}
	button:hover {
		background: var(--color-accent-hover);
	}
</style>

<script>
	import { diasTotalesAPosicion, formatearPosicion } from "../core";

	const input = document.getElementById("birthdate") as HTMLInputElement;
	const refInput = document.getElementById("refdate") as HTMLInputElement;
	const btn = document.getElementById("calcular") as HTMLButtonElement;
	const valores = document.querySelectorAll(
		".card .value",
	) as NodeListOf<HTMLElement>;
	const compacta = document.querySelector(".compact") as HTMLElement;
	const subtitulo = document.querySelector(".subtitle") as HTMLElement;

	const hoy = new Date();
	const hoyStr = `${hoy.getFullYear()}-${String(hoy.getMonth() + 1).padStart(2, "0")}-${String(hoy.getDate()).padStart(2, "0")}`;
	input.max = hoyStr;
	refInput.value = hoyStr;

	function mostrarEra(nacimiento: Date, referencia: Date) {
		const refLocal = new Date(referencia.getFullYear(), referencia.getMonth(), referencia.getDate(), 12);
		const diasTotales = Math.floor((refLocal.getTime() - nacimiento.getTime()) / 86400000);
		const pos = diasTotalesAPosicion(diasTotales);
		const labels = [pos.era, pos.periodo, pos.semana, pos.dia];

		valores.forEach((el, i) => { el.textContent = String(labels[i]) });
		compacta.textContent = `[ ${labels.join(' | ')} ]`;
		subtitulo.textContent = formatearPosicion(pos);
	}

	function calcular() {
		if (!input.value || !refInput.value) return;
		const [y, m, d] = input.value.split("-").map(Number);
		const [ry, rm, rd] = refInput.value.split("-").map(Number);
		mostrarEra(new Date(y, m - 1, d, 12), new Date(ry, rm - 1, rd));
	}

	input.addEventListener("change", calcular);
	refInput.addEventListener("change", calcular);
	btn.addEventListener("click", calcular);

	subtitulo.addEventListener("click", () => {
		navigator.clipboard.writeText(subtitulo.textContent ?? '')
	})

	compacta.addEventListener("click", () => {
		navigator.clipboard.writeText(compacta.textContent ?? '')
	})
</script>
