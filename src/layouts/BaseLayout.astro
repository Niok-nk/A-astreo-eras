---
import '../styles/global.css';
import ParticlesBackground from '../components/ParticlesBackground.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Reloj de Eras — descubre en qué Era, Período y Semana estás" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Astreo | Eras</title>
  </head>
  <body>
    <ParticlesBackground />
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  main {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column-reverse;
    justify-content: center;
    align-items: center;
    padding: 2rem 1rem;
  }

  @media (min-width: 768px) {
    main {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 0 1rem ;
      gap: 3rem;
    }
  }
</style>
